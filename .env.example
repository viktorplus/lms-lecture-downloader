# Скопируй этот файл в .env и заполни значения.
# .env в гит не коммитится (см. .gitignore).

# Учётные данные LMS
LMS_EMAIL=you@example.com
LMS_PASSWORD=your_password

# Куда сохранять лекции
TARGET_ROOT=E:/git/ich_pdf_lesson

# Адрес LMS (менять только при смене домена)
LMS_BASE=https://lms.itcareerhub.de

# true — браузер в фоне, false — видимый
HEADLESS=true
